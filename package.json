{
  "name": "kiriakou",
  "version": "0.1.0",
  "description": "Post-2FA humanity verification for Nuxt — confirms a human, not an automated session, is driving after login.",
  "type": "module",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "2fa",
    "bot-detection",
    "humanity",
    "captcha",
    "security"
  ],
  "exports": {
